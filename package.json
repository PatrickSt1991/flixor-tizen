{
  "name": "flixor",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "npm run build:core",
    "build:core": "npm run build --workspace=@flixor/core",
    "dev:core": "npm run dev --workspace=@flixor/core"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
